<Window x:Class="Luxolo_s_Cyberbot_GUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CyberBot - Advanced Cybersecurity Assistant"
        Height="750" Width="1000"
        WindowStartupLocation="CenterScreen"
        Background="#0B0E14"
        ResizeMode="CanResize">

    <Window.Resources>
        <!-- ── Smooth Slide-In & Fade-In Animations for Chat Bubbles ── -->
        <Style x:Key="AnimatedBubbleStyle" TargetType="Border">
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <TranslateTransform Y="30"/>
                </Setter.Value>
            </Setter>
            <Setter Property="Opacity" Value="0"/>
            <Style.Triggers>
                <EventTrigger RoutedEvent="Loaded">
                    <BeginStoryboard>
                        <Storyboard>
                            <!-- Fade-in transition -->
                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                             To="1" Duration="0:0:0.45" 
                                             DecelerationRatio="0.9"/>
                            <!-- Slide-up transition -->
                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                                             To="0" Duration="0:0:0.4" 
                                             DecelerationRatio="0.9"/>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <!-- Main grid defining a sidebar and main chat room -->
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280"/>
            <!-- Left Control Panel & Stats Sidebar -->
            <ColumnDefinition Width="*"/>
            <!-- Right Main Chat Console -->
        </Grid.ColumnDefinitions>

        <!-- ═══════════════════════════════════════════════════
             COL 0: Dynamic Left Sidebar (Interactive Stats & Bot Status)
             ═══════════════════════════════════════════════════ -->
        <Border Grid.Column="0" Background="#111622" BorderBrush="#1F293D" BorderThickness="0,0,1,0">
            <Grid Margin="20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Bot Status Widget -->
                <StackPanel Grid.Row="0" Margin="0,0,0,20">
                    <Border CornerRadius="50" Width="90" Height="90" Background="#1D2A3A" BorderBrush="#00FF99" BorderThickness="2" HorizontalAlignment="Center">
                        <TextBlock Text="🤖" FontSize="44" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,0,0,4"/>
                    </Border>
                    <TextBlock Text="CYBERBOT v3.0" Foreground="#00FF99" FontWeight="Bold" FontFamily="Segoe UI" FontSize="16" TextAlignment="Center" Margin="0,12,0,2"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Ellipse Width="8" Height="8" Fill="#00FF99" Margin="0,0,6,0" VerticalAlignment="Center">
                            <Ellipse.Triggers>
                                <EventTrigger RoutedEvent="Loaded">
                                    <BeginStoryboard>
                                        <Storyboard RepeatBehavior="Forever">
                                            <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0.3" To="1" Duration="0:0:1" AutoReverse="True"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                            </Ellipse.Triggers>
                        </Ellipse>
                        <TextBlock Text="AGENT ACTIVE" Foreground="#8B949E" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    </StackPanel>
                </StackPanel>

                <!-- User Profile Memory Recall Display -->
                <StackPanel Grid.Row="1" VerticalAlignment="Top" Margin="0,10,0,0">
                    <Border Background="#1A2234" CornerRadius="8" Padding="15" Margin="0,0,0,15">
                        <StackPanel>
                            <TextBlock Text="USER MEMORY BANK" Foreground="#00E1FF" FontSize="11" FontWeight="Bold" Margin="0,0,0,10"/>
                            <StackPanel Orientation="Horizontal" Margin="0,4">
                                <TextBlock Text="User:" Foreground="#8B949E" Width="60" FontSize="12"/>
                                <TextBlock x:Name="TxtMemName" Text="Not set yet" Foreground="White" FontWeight="SemiBold" FontSize="12"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,4">
                                <TextBlock Text="Topic:" Foreground="#8B949E" Width="60" FontSize="12"/>
                                <TextBlock x:Name="TxtMemTopic" Text="None" Foreground="White" FontWeight="SemiBold" FontSize="12" TextTrimming="CharacterEllipsis"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,4">
                                <TextBlock Text="Interest:" Foreground="#8B949E" Width="60" FontSize="12"/>
                                <TextBlock x:Name="TxtMemInterest" Text="Undecided" Foreground="White" FontWeight="SemiBold" FontSize="12" TextTrimming="CharacterEllipsis"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,4">
                                <TextBlock Text="Feeling:" Foreground="#8B949E" Width="60" FontSize="12"/>
                                <TextBlock x:Name="TxtMemFeeling" Text="Neutral" Foreground="White" FontWeight="SemiBold" FontSize="12"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border Background="#1A2234" CornerRadius="8" Padding="15">
                        <StackPanel>
                            <TextBlock Text="SUGGESTED KEYWORDS" Foreground="#FF9E00" FontSize="11" FontWeight="Bold" Margin="0,0,0,8"/>
                            <TextBlock Text="• phishing / passwords&#x0a;• malware / ransomware&#x0a;• scams / identity theft&#x0a;• social media / privacy&#x0a;• 2FA / VPN / firewalls&#x0a;• cookies / encryption" 
                                       Foreground="#A5B4FC" FontSize="12" LineHeight="18" FontFamily="Consolas"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Footer disclaimer -->
                <TextBlock Grid.Row="2" Text="Designed for South African CyberSafety&#x0a;PROG6221 Portfolio Standard" Foreground="#4B5563" FontSize="10" TextAlignment="Center" LineHeight="14"/>
            </Grid>
        </Border>

        <!-- ═══════════════════════════════════════════════════
             COL 1: Premium Main Chat Console
             ═══════════════════════════════════════════════════ -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <!-- Upper Header -->
                <RowDefinition Height="*"/>
                <!-- Chat Log View -->
                <RowDefinition Height="Auto"/>
                <!-- Text Inputs -->
            </Grid.RowDefinitions>

            <!-- Top Header banner -->
            <Border Grid.Row="0" Background="#111622" Padding="25,15" BorderBrush="#1F293D" BorderThickness="0,0,0,1">
                <DockPanel>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="🔒 SAFESHIELD INTERACTIVE" Foreground="White" FontSize="18" FontWeight="ExtraBold" FontFamily="Segoe UI"/>
                        <TextBlock Text="Empowering users through responsive digital cybersecurity training." Foreground="#8B949E" FontSize="11" Margin="0,2,0,0"/>
                    </StackPanel>
                    <Button Content="Clear History" Click="BtnClear_Click" DockPanel.Dock="Right" HorizontalAlignment="Right" Background="#242E42" Foreground="#8B949E" Padding="12,5" BorderThickness="0" Cursor="Hand" VerticalAlignment="Center">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="4"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </DockPanel>
            </Border>

            <!-- Chat Logger View -->
            <ScrollViewer Grid.Row="1" x:Name="ChatScroller" Background="#0C101B" VerticalScrollBarVisibility="Auto" Padding="20,10">
                <StackPanel x:Name="ChatPanel" Margin="0,0,0,10"/>
            </ScrollViewer>

            <!-- Bottom typing inputs layout -->
            <Border Grid.Row="2" Background="#111622" BorderBrush="#1F293D" BorderThickness="0,1,0,0" Padding="20">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Text input box -->
                    <TextBox x:Name="UserInput" Grid.Column="0"
                             Background="#1A2234" Foreground="White" CaretBrush="#00FF99"
                             FontFamily="Segoe UI" FontSize="14" Padding="15,12"
                             BorderBrush="#2A3852" BorderThickness="1.5" VerticalContentAlignment="Center"
                             KeyDown="UserInput_KeyDown" GotFocus="UserInput_GotFocus" LostFocus="UserInput_LostFocus"
                             Tag="Ask about safe browsing, malware, encryption, scams..."/>

                    <!-- Glowing interactive send button -->
                    <Button x:Name="SendButton" Grid.Column="1"
                            Content="Send Message ➤" Margin="15,0,0,0" Padding="25,0"
                            Background="#00CD76" Foreground="White"
                            FontFamily="Segoe UI" FontSize="14" FontWeight="Bold"
                            BorderThickness="0" Cursor="Hand" Click="SendButton_Click">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#00FF90"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>